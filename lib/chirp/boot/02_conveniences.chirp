//         bp = (this, v) => v == this,
//         br = (this, lc) =>
//           if (this ∉ lc) {false}
//           else if ({this} == lc) {true}
//           else {true, false}
//      ));
//    };
//
//    make_type_a_self_set(bool);
//    make_type_a_self_set(int);
//    make_type_a_self_set(string);
//    make_type_a_self_set(`typeof(undecided));
// };


// We could just force returning from main. But being able to bail out is nice and easy to implement, 
// and it's not like it adds much complexity.
let final `exit = `import("exit_func", "__chirp_boot");
