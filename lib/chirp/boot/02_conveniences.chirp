// N.B. This file, as well has others in the `boot` directory operate under special rules:
// - `import` with format "__chirp_boot" is available. Normal scripts are forbidden from using this format.
// - backtick-prefixed identifiers can be defined here. Normal scripts can only read them, not define them.
// - Identifiers defined here appear in the global namespace. This is the only place where that happens.

// pre-defined ranges that match the usual suspects. Very important for forcing code into a machine-emmitable shape.
let final int8 = -128..=127;
let final int16 = -32768..=32767;
let final int32 = -2147483648..=2147483647;
let final int64 = -9223372036854775808..=9223372036854775807;

let final uint8 = 0..=255;
let final uint16 = 0..=65535;
let final uint32 = 0..=4294967295;
// TODO: This needs an unsigned or bigint-backed value model.
//let final uint64 = 0..=18446744073709551615;


// ---------- literals as singleton sets ----------

// Without these, we'd have to wrap every literal in a singleton set when matching, ew!
// It also doesn't conflict with anything because none of them are sets.
//
// match (v) => {
//   {0} => "zero"
//   {1} => "one"
//   `any => "other"
// }
// 

// N.B. `inject_set_capability() and Setness are real things yet, and the actual machinery will likely be different. 
// // The do is to avoid bleeding out the intermediate symbol into the global namespace.
