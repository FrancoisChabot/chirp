`expect_stdout("1\n2\nFizz\n4\nBuzz\nFizz\n7\n8\nFizz\nBuzz\n11\nFizz\n13\n14\nFizzBuzz\n");
`expect_exit(0);

for (n ∈ 1..=15) do {
    if (n % 15 == 0) do {
        `print("FizzBuzz");
    } else if (n % 3 == 0) do {
        `print("Fizz");
    } else if (n % 5 == 0) do {
        `print("Buzz");
    } else do {
        `print(n);
    };
};
