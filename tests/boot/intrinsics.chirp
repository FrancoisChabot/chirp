`expect_exit(0);

`expect_stdout("--- Type Identities ---\n");
`print("--- Type Identities ---");
`expect(`typeof(true) == bool);
`expect(`typeof(false) == bool);
`expect(`typeof(1) == int);
`expect(`typeof("") == string);
`expect(`typeof(bool) == `type);
`expect(`typeof(int) == `type);
`expect(`typeof(string) == `type);
`expect(`typeof(`type) == `type);

`expect_stdout("--- Membership Relations ---\n");
`print("--- Membership Relations ---");
`expect(true ∈ bool);
`expect(false ∈ bool);
`expect(1 ∈ int);
`expect("" ∈ string);
`expect(bool ∈ `type);
`expect(int ∈ `type);
`expect(string ∈ `type);
`expect(`type ∈ `type);

`expect_stdout("--- Set Capability Relations ---\n");
`print("--- Set Capability Relations ---");
`expect(bool ∈ `set);
`expect(int ∈ `set);
`expect(string ∈ `set);
`expect(`type ∈ `set);
`expect(`any ∈ `set);
`expect(`empty ∈ `set);
`expect(`set ∈ `set);
`expect(true ∈ `set);
`expect(1 ∈ `set);
`expect("" ∈ `set);

`expect_stdout("--- Top (any) and Bottom (empty) Relations ---\n");
`print("--- Top (any) and Bottom (empty) Relations ---");
`expect(true ∈ `any);
`expect(1 ∈ `any);
`expect("" ∈ `any);
`expect(`type ∈ `any);
`expect(`any ∈ `any);
`expect(true ∉ `empty);
`expect(1 ∉ `empty);
`expect("" ∉ `empty);
`expect(`type ∉ `empty);
`expect(`empty ∉ `empty);
