`expect_exit(0);

let Token = `mint_finite(1).values[0];

`implement(
    trait=`Callable,
    on=`nature_of(Token),
    impl={
        param_space = (this) => struct {x: int, y: int},
        result_space = (this, params) => int,
        invoke = (this, args) => args.x - args.y
    }
);

let result = Token(y=2, x=10);
`expect(result == 8);

let result2 = Token(10, 2);
`expect(result2 == 8);

let result3 = Token(y=20, x=30);
`expect(result3 == 10);
