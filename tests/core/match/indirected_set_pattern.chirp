// Match patterns can be stored in bindings (indirected sets), since patterns
// are just ordinary set values.
`expect_exit(0);

let even = {x : int | x % 2 == 0};
let odd = {x : int | x % 2 != 0};

let parity(n) = match n {
    even => "even",
    odd => "odd"
};

`expect_stdout("even\n");
`print(parity(4));
`expect_stdout("odd\n");
`print(parity(7));
`expect_stdout("even\n");
`print(parity(0));
