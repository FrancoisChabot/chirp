// Types are sets of their instances. Using a type like `int` as a match
// pattern tests `subject ∈ int`, i.e. `type_of(subject) == int`.
`expect_exit(0);

let describe(v) = match v {
    int => "integer",
    bool => "boolean",
    string => "text",
    `any => "unknown"
};

`expect_stdout("integer\n");
`print(describe(42));
`expect_stdout("boolean\n");
`print(describe(true));
`expect_stdout("text\n");
`print(describe("hello"));
