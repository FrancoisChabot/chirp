// Match with set union (∪) in a pattern. The subject is tested for membership
// in the union of the two sets.
`expect_exit(0);

let low = {1, 2, 3};
let high = {98, 99, 100};

let classify(n) = match n {
    low ∪ high => "special",
    `any => "normal"
};

`expect_stdout("special\n");
`print(classify(2));
`expect_stdout("special\n");
`print(classify(99));
`expect_stdout("normal\n");
`print(classify(50));
