`expect_exit(0);
`expect_stdout("after\ndrop\ndrop\n");

let heap = `import("std/heap");
let Token = struct {};

`implement(
    trait=`Drop,
    on=Token,
    impl=`interface(`Drop)(drop=(this) => `print("drop"))
);

do {
    let mut p = heap.shared(Token());
    let q = p;
    p = heap.shared(Token());
    `print("after");
};
