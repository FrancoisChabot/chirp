`expect_exit(0);
`expect_stdout("drop\nafter\ndrop\n");

let heap = `import("std/heap");
let Token = struct {};

`implement(
    trait=`drop,
    on=Token,
    impl=`Dropness(drop=(this) => `print("drop"))
);

do {
    let mut p = heap.create(Token());
    p = heap.create(Token());
    `print("after");
};
