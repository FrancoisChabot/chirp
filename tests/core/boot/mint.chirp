`expect_exit(0);

let a = `mint_finite(1).values[0];
let same = a;
let b = `mint_finite(1).values[0];
let constrained : `nature_of(a) = a;

`expect(a == same);
`expect(a != b);
`expect(`nature_of(a) == `nature_of(same));
`expect(`nature_of(a) != `nature_of(b));
`expect(a ∈ `nature_of(a));
`expect(a ∉ `nature_of(b));
`expect(b ∈ `nature_of(b));
`expect(a ∉ `Set);
`expect(`nature_of(a) ∈ `nature);
`expect(`nature_of(a) ∈ `Set);
`expect(constrained == a);
