`expect_exit(0);

let a = `mint_finite(1).values[0];
let same = a;
let b = `mint_finite(1).values[0];
let constrained : `type_of(a) = a;

`expect(a == same);
`expect(a != b);
`expect(`type_of(a) == `type_of(same));
`expect(`type_of(a) != `type_of(b));
`expect(a ∈ `type_of(a));
`expect(a ∉ `type_of(b));
`expect(b ∈ `type_of(b));
`expect(a ∉ `Set);
`expect(`type_of(a) ∈ `type);
`expect(`type_of(a) ∈ `Set);
`expect(constrained == a);
