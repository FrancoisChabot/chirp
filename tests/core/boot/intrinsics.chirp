`expect_exit(0);

`expect_stdout("--- Type Identities ---\n");
`print("--- Type Identities ---");
`expect(`type_of(true) == bool);
`expect(`type_of(false) == bool);
`expect(`type_of(1) == int);
`expect(`type_of("") == string);
`expect(`type_of(bool) == `type);
`expect(`type_of(int) == `type);
`expect(`type_of(string) == `type);
`expect(`type_of(`type) == `type);

`expect_stdout("--- Membership Relations ---\n");
`print("--- Membership Relations ---");
`expect(true ∈ bool);
`expect(false ∈ bool);
`expect(1 ∈ int);
`expect("" ∈ string);
`expect(bool ∈ `type);
`expect(int ∈ `type);
`expect(string ∈ `type);
`expect(`type ∈ `type);

`expect_stdout("--- Set Capability Relations ---\n");
`print("--- Set Capability Relations ---");
`expect(bool ∈ `Set);
`expect(int ∈ `Set);
`expect(string ∈ `Set);
`expect(`type ∈ `Set);
`expect(`any ∈ `Set);
`expect(`empty ∈ `Set);
`expect(`Set ∈ `Set);
`expect(true ∈ `Set);
`expect(1 ∈ `Set);
`expect("" ∈ `Set);

`expect_stdout("--- Top (any) and Bottom (empty) Relations ---\n");
`print("--- Top (any) and Bottom (empty) Relations ---");
`expect(true ∈ `any);
`expect(1 ∈ `any);
`expect("" ∈ `any);
`expect(`type ∈ `any);
`expect(`any ∈ `any);
`expect(true ∉ `empty);
`expect(1 ∉ `empty);
`expect("" ∉ `empty);
`expect(`type ∉ `empty);
`expect(`empty ∉ `empty);
