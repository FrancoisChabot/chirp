`expect_exit(0);

`expect_stdout("--- Nature Identities ---\n");
`print("--- Nature Identities ---");
`expect(`nature_of(true) == bool);
`expect(`nature_of(false) == bool);
`expect(`nature_of(1) == int);
`expect(`nature_of("") == string);
`expect(`nature_of(bool) == `nature);
`expect(`nature_of(int) == `nature);
`expect(`nature_of(string) == `nature);
`expect(`nature_of(`nature) == `nature);

`expect_stdout("--- Membership Relations ---\n");
`print("--- Membership Relations ---");
`expect(true ∈ bool);
`expect(false ∈ bool);
`expect(1 ∈ int);
`expect("" ∈ string);
`expect(bool ∈ `nature);
`expect(int ∈ `nature);
`expect(string ∈ `nature);
`expect(`nature ∈ `nature);

`expect_stdout("--- Set Capability Relations ---\n");
`print("--- Set Capability Relations ---");
`expect(bool ∈ `Set);
`expect(int ∈ `Set);
`expect(string ∈ `Set);
`expect(`nature ∈ `Set);
`expect(`any ∈ `Set);
`expect(`empty ∈ `Set);
`expect(`Set ∈ `Set);
`expect(true ∈ `Set);
`expect(1 ∈ `Set);
`expect("" ∈ `Set);

`expect_stdout("--- Top (any) and Bottom (empty) Relations ---\n");
`print("--- Top (any) and Bottom (empty) Relations ---");
`expect(true ∈ `any);
`expect(1 ∈ `any);
`expect("" ∈ `any);
`expect(`nature ∈ `any);
`expect(`any ∈ `any);
`expect(true ∉ `empty);
`expect(1 ∉ `empty);
`expect("" ∉ `empty);
`expect(`nature ∉ `empty);
`expect(`empty ∉ `empty);
