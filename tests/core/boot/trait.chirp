`expect_exit(0);

let Marker = `make_trait(void);
let Other = `make_trait(void);

`implement(
    trait=Marker,
    on=int,
    impl=void
);



`expect(1 ∈ Marker);

`expect("" ∉ Marker);

`expect(Marker ∈ `Set);

`expect(Marker != Other);

`expect(1 ∉ Other);

`expect(`interface_of(Marker) == void);
`expect(`implementation(Marker, int) == void);

let constrained : Marker = 5;

`expect(constrained == 5);

`expect(Marker ∈ `type_of(Marker));
