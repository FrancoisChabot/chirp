`expect_exit(0);

let Marker = `trait(`any);
let Other = `trait(`any);

`implement(
    trait=Marker,
    on=int,
    impl=#marker_impl
);

`expect(`interface(Marker) == `any);

`expect(1 ∈ Marker);

`expect("" ∉ Marker);

`expect(Marker ∈ `Set);

`expect(Marker != Other);

`expect(1 ∉ Other);

let constrained : Marker = 5;

`expect(constrained == 5);

`expect(Marker ∈ `typeof(Marker));
