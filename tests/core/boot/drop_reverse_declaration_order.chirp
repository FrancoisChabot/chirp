`expect_exit(0);
`expect_stdout("B\nA\n");

let A = struct {};
let B = struct {};

`implement(
    trait=`Drop,
    on=A,
    impl=`interface_of(`Drop)(drop=(this) => `print("A"))
);

`implement(
    trait=`Drop,
    on=B,
    impl=`interface_of(`Drop)(drop=(this) => `print("B"))
);

do {
    let a = A();
    let b = B();
};
