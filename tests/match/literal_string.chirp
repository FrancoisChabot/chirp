// Match against string literal patterns. Each string literal acts as a
// singleton set for membership testing.
`expect_exit(0);

let check_keyword(lexeme) = match lexeme {
    "let" => #let,
    "if" => #if,
    "in" => #in,
    `any => #identifier
};

`expect_stdout("#in\n");
`print(check_keyword("in"));
