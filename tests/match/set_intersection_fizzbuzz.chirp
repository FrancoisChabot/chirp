// Set intersection (∩) can be used in match patterns. The classic example:
// fizzbuzz with sets.
`expect_stdout("1\n2\nfizz\n4\nbuzz\nfizz\n7\n8\nfizz\nbuzz\n11\nfizz\n13\n14\nfizzbuzz\n");
`expect_interpreter_exit(0);

let fizz = {x : int | x % 3 == 0};
let buzz = {x : int | x % 5 == 0};

for (v ∈ 1..=15) do {
    let out = match v {
        fizz ∩ buzz => "fizzbuzz",
        fizz => "fizz",
        buzz => "buzz",
        `any => v
    };
    `print(out);
};
