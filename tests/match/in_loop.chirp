// Match used inside a for loop with computed subject expression.
`expect_test_failure;
`expect_stdout("odd\neven\nodd\neven\n");
`expect_exit(0);

let even = {x : int | x % 2 == 0};
let odd = {x : int | x % 2 != 0};

for (n ∈ 1..=4) do {
    `print(match n {
        even => "even",
        odd => "odd"
    });
};
