// A match pattern can be a constructed set (comprehension). The subject is
// tested for membership via the comprehension's belonging predicate.
`expect_stdout("positive\nnon-positive\n");
`expect_interpreter_exit(0);

let classify(n) = match n {
    {x : int | x > 0} => "positive",
    `any => "non-positive"
};

`print(classify(5));
`print(classify(-3));
