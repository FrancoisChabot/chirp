// Match can be used as a mapping function (finite matching function).
// This pattern is used throughout the examples for lookup tables.
// Symbolic constant pattern matching test
`expect_stdout("16\n18\n0\n");
`expect_interpreter_exit(0);

let BP(op_type) = match op_type {
    {#plus, #minus} => 16,
    {#star, #slash} => 18,
    `any => 0
};

`print(BP(#plus));
`print(BP(#star));
`print(BP(#unknown));
