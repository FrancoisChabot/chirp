// Range patterns: ranges are sets, so `1..4` as a pattern tests `subject ∈ 1..4`.
`expect_stdout("low\nmid\nhigh\n");
`expect_exit(0);

let classify(n) = match n {
    1..=3 => "low",
    4..=6 => "mid",
    7..=9 => "high",
    `any => "out of range"
};

`print(classify(2));
`print(classify(5));
`print(classify(8));
