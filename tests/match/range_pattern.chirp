// Range patterns: ranges are sets, so `1..4` as a pattern tests `subject ∈ 1..4`.
`expect_exit(0);

let classify(n) = match n {
    1..=3 => "low",
    4..=6 => "mid",
    7..=9 => "high",
    `any => "out of range"
};

`expect_stdout("low\n");
`print(classify(2));
`expect_stdout("mid\n");
`print(classify(5));
`expect_stdout("high\n");
`print(classify(8));
